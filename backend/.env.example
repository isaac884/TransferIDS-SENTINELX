APP_ENV=development
API_PREFIX=/api/v1
DATABASE_URL=postgresql+psycopg://postgres:0000@127.0.0.1:5432/transferids_web3
DATABASE_REQUIRED=false
REDIS_URL=redis://127.0.0.1:6379/0
JWT_SECRET=change-me-before-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_MINUTES=120
AUTH_REQUIRED=true
ALLOW_SELF_REGISTRATION=true
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_PASSWORD=replace-with-strong-local-password
BOOTSTRAP_ADMIN_ROLE=admin
BOOTSTRAP_ADMIN_RESET_PASSWORD=false
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:8080,http://127.0.0.1:8080
MODEL_ARTIFACT_PATH=backend/app/ml/artifacts/transferids_c3.onnx
MODEL_METADATA_PATH=backend/app/ml/artifacts/transferids_c3.metadata.json
ATTACK_THRESHOLD=0.5
